# Supabase REST API (same as Python backend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_ANON_KEY=your-anon-key

# Supabase direct Postgres connection
# Get from: Supabase dashboard > Settings > Database > Connection string (URI)
# Format: jdbc:postgresql://db.xxxx.supabase.co:5432/postgres
SUPABASE_DB_URL=jdbc:postgresql://db.xxxx.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-database-password

# Director PIN (same as Python backend)
DIRECTOR_PIN=your-pin
