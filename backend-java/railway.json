{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mvn package -DskipTests"
  },
  "deploy": {
    "startCommand": "java -jar target/setpoint-backend-0.0.1-SNAPSHOT.jar",
    "healthcheckPath": "/sessions",
    "restartPolicyType": "ON_FAILURE"
  }
}
